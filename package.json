{
  "name": "sde-platform",
  "version": "2.0.0",
  "description": "Secure Data Exchange Platform v2",
  "main": "dist/server.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node -r dotenv/config dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/ --ext .ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "create-admin": "tsx src/scripts/createAdmin.ts"
  },
  "keywords": [
    "encryption",
    "ecies",
    "webcrypto"
  ],
  "author": "Vaibhav Sharma",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@noble/curves": "^1.8.1",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "web-push": "^3.6.7",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.13.4",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.14",
    "@vitest/coverage-v8": "^3.0.5",
    "dotenv": "^17.4.2",
    "eslint": "^9.20.1",
    "prettier": "^3.5.1",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
